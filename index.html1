<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Niğde Bor Gazozu | Ödev Çalışması</title>
  <style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:wght@600;700&display=swap');

:root{
  --bg:#070a12;
  --text:#e9eefc;
  --muted:#94a3c7;
  --brand:#66e3c4;
  --line: rgba(255,255,255,.08);
  --shadow: 0 14px 40px rgba(0,0,0,.45);
}

*{ margin:0; padding:0; box-sizing:border-box; }
html{ scroll-behavior: smooth; }
body{
  font-family: Inter, system-ui;
  color:var(--text);
  background: var(--bg);
}

.container{ width:min(1120px, 92%); margin:0 auto; }

.hero{
  padding: 90px 0 60px;
  background:
    linear-gradient(180deg, rgba(7,10,18,.71), rgba(7,10,18,.94)),
    url("https://i.imgur.com/9ZkL7wQ.jpeg");
  background-size: cover;
  background-position: center;
  border-bottom: 1px solid var(--line);
}

.hero h1{
  font-family: Playfair Display;
  font-size: 48px;
  margin-bottom: 12px;
  letter-spacing: -0.7px;
}

.hero p{
  color: var(--muted);
  font-size: 17px;
  line-height: 1.6;
  max-width: 550px;
  margin-bottom: 24px;
}

.cta{ display:flex; gap:12px; flex-wrap:wrap; }
.btn{
  padding: 11px 18px;
  border-radius: 12px;
  background: linear-gradient(135deg, #66e3c4, #44c5a7);
  color: #051a14;
  font-weight: 700;
  text-decoration: none;
  box-shadow: var(--shadow);
}

.section{ padding: 50px 0; }
.section.alt{
  background: rgba(255,255,255,.02);
  border-block: 1px solid var(--line);
}

h2{
  font-family: Playfair Display;
  font-size: 28px;
  margin-bottom: 16px;
}

.grid{ display:grid; gap:16px; }
.grid.three{ grid-template-columns: repeat(3,1fr); }

.gal{
  width: 100%;
  height: 200px;
  object-fit: cover;
  border-radius: 16px;
  border: 1px solid var(--line);
  transition: 0.2s;
}
.gal:hover{ transform: translateY(-2px); filter: brightness(1.05); }

.note{
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid var(--line);
  color: rgba(233,238,252,.6);
  font-size: 12px;
}

@media (max-width: 820px){
  .hero h1{ font-size: 34px; }
  .grid.three{ grid-template-columns: 1fr; }
}

  </style>
</head>
<body>

  <section class="hero">
    <div class="container">
      <h1>Niğde Bor Gazozu</h1>
      <p>İç Anadolu'nun en bilinen yerel lezzeti, birkaç nesildir bütün Niğde'nin hafızasında yer alan serinletici klasik.</p>
      <div class="cta">
        <a class="btn" href="#hakkinda">Tanıtımı Oku</a>
        <a class="btn" href="#galeri">Galeriyi Gör</a>
      </div>
    </div>
  </section>

  <section id="hakkinda" class="section">
    <div class="container">
      <h2>Hakkında</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Bor ilçesine özgü bu gazoz kültürü, 1970'li yıllardan günümüze kadar gelmiştir. Sadece tat olarak değil, yaz akşamları, pikniklerde, arkadaş toplantılarında paylaşılan bir anı olarak da yaşamaktadır.
      </p>
    </div>
  </section>

  <section id="galeri" class="section alt">
    <div class="container">
      <h2>Galeri</h2>
      <div class="grid three">
        <img class="gal" src="https://i.imgur.com/d7XfQcB.jpeg" alt="Cam şişe gazoz">
        <img class="gal" src="https://i.imgur.com/9ZkL7wQ.jpeg" alt="Premium ürün görseli">
        <img class="gal" src="https://i.imgur.com/tRkP8xB.jpeg" alt="Lifestyle görsel">
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="note">
        ✅ Bu çalışma bir okul ödevi kapsamında hazırlanmıştır.<br>
        ✅ Tüm görseller yapay zeka ile üretilmiştir.
      </div>

    </div>
  </section>

</body>
</html>
